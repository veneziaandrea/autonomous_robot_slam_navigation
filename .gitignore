# ROS1 build and development folders at the workspace root
catkin_ws/build/ 
catkin_ws/devel/ 
catkin_ws/install/ # Colcon install directory (if applicable, also at workspace root)

# Ignore the autogenerated CMakeLists.txt in the workspace's src folder.
# Note: This is typically the CMakeLists.txt that includes sub-packages in a workspace.
catkin_ws/src/CMakeLists.txt

# ROS specific files and directories (within packages or at workspace level)
log/                        # ROS log files
*.bag                       # ROS Bag files 
*.rosbag                    # Another common extension for ROS Bag files

# Common editor and IDE temporary/config files
*~                          # Temporary files (often created by text editors like Emacs)
*.swp                       # Vim swap files
*.swo                       # Vim swap files
.vscode/                    # VS Code settings folder
.idea/                      # IntelliJ/CLion project files
.project                    # Eclipse project file
.cproject                   # Eclipse C/C++ project file
.settings/                  # Eclipse settings folder

# C++ build artifacts
*.o                         # Object files
*.a                         # Static libraries
*.so                        # Shared libraries
*.dll                       # Dynamic link libraries
*.d                         # Dependency files generated by compilers

# OS generated files
.DS_Store                   # macOS generated files
.Trash/                     # macOS trash folder
Thumbs.db                   # Windows thumbnail cache
ehthumbs.db                 # Windows thumbnail cache
*.stackdump                 # Windows crash dumps